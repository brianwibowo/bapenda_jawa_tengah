# ============================================
# Bapenda Jateng — Production Environment
# audira.site
# ============================================

APP_NAME="Bapenda_Jateng"
APP_ENV=production
APP_KEY=base64:tXHwoWm5YhEGOBY+OBJPuKH79qDfWeBCokx5AAiBSVs=
APP_DEBUG=false
APP_URL=https://audira.site

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (Docker internal network) ───────
# DB_HOST=db → this is the Docker service name, NOT 127.0.0.1
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=bapenda_new
DB_USERNAME=root
DB_PASSWORD=passwordBaru123

# ── Session ──────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue & Cache ────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# ── Vite ─────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
